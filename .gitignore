# ── Chimera .gitignore ───────────────────────────────────────────────
# Public repo, private work. Tracked content stays generic & reusable.

# Private / branded workflows  ── keep these OUT of the public repo
workflows/personal/
!workflows/personal/.gitkeep
# name any private workflow *.local.json -> ignored anywhere
*.local.json

# Generated media
outputs/
!outputs/.gitkeep
*.png
*.jpg
*.jpeg
*.webp
*.mp4
*.mov
*.webm
*.gif
*.wav
*.mp3
*.flac
*.glb
*.obj
*.stl
*.ply
*.3mf
# (allow committed example thumbnails if you ever need them)
!docs/**/*.png
!docs/**/*.jpg

# Model weights & caches  ── never commit; reference by URL in models.md
models/
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.gguf
*.onnx

# Secrets / local config
.env
.env.*
!.env.example

# Internal development planning docs (kept local; not part of the public surface)
docs/superpowers/

# ComfyUI runtime cruft (if ComfyUI lives inside the repo)
ComfyUI/output/
ComfyUI/temp/
ComfyUI/input/
ComfyUI/models/
ComfyUI/user/
custom_nodes/*/
!custom_nodes/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
build/
.ipynb_checkpoints/

# Node (if the MCP server is JS/TS)
node_modules/
dist/
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# ── Brand Kits ── pattern public, brand data private
# Everything directly under brands/ is private by default (real brands stay local)...
brands/*
# ...except the readme, the starter template, and the public showcase brand, which are
# tracked IN FULL — including their outputs/ — so the example pipeline is complete and
# reproducible for anyone who clones the repo.
!brands/README.md
!brands/_template/
!brands/_template/**
!brands/example-brand/
!brands/example-brand/**
# Never commit trained model weights or the regenerable trainer config, even for the
# example brand: large binaries / generated artifacts — reproduce them from training/
# + brand.yaml. (These override the broad re-include just above.)
brands/example-brand/**/*.safetensors
brands/example-brand/**/*.ckpt
brands/example-brand/**/*.pt
brands/example-brand/**/*.pth
brands/example-brand/**/*.bin
brands/example-brand/**/*.gguf

# Test artifacts
.coverage
htmlcov/
.pytest_cache/
